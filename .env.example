PORT=3000

# Shopify
# Use your Shopify app client secret. Shopify signs HTTPS webhook deliveries with this.
SHOPIFY_WEBHOOK_SECRET=

# Zoho OAuth
# For India accounts use https://accounts.zoho.in and https://www.zohoapis.in.
# For US/global accounts use https://accounts.zoho.com and https://www.zohoapis.com.
ZOHO_ACCOUNTS_DOMAIN=https://accounts.zoho.com
ZOHO_API_DOMAIN=https://www.zohoapis.com
ZOHO_CLIENT_ID=
ZOHO_CLIENT_SECRET=
ZOHO_REFRESH_TOKEN=
ZOHO_ORGANIZATION_ID=
ZOHO_DEFAULT_ITEM_ID=
ZOHO_DEFAULT_TAX_ID=

# Optional
ZOHO_DEFAULT_PAYMENT_TERMS=0
