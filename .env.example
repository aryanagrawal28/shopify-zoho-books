PORT=3000

# Shopify
# Use your Shopify app client secret. Shopify signs HTTPS webhook deliveries with this.
SHOPIFY_WEBHOOK_SECRET=
# Optional but recommended for refunds/create webhooks, so the app can fetch
# the Shopify order name from order_id and match the original Zoho invoice.
SHOPIFY_ADMIN_ACCESS_TOKEN=
SHOPIFY_SHOP_DOMAIN=
SHOPIFY_API_VERSION=2026-07

# Zoho OAuth
# For India accounts use https://accounts.zoho.in and https://www.zohoapis.in.
# For US/global accounts use https://accounts.zoho.com and https://www.zohoapis.com.
ZOHO_ACCOUNTS_DOMAIN=https://accounts.zoho.com
ZOHO_API_DOMAIN=https://www.zohoapis.com
ZOHO_CLIENT_ID=
ZOHO_CLIENT_SECRET=
ZOHO_REFRESH_TOKEN=
ZOHO_ORGANIZATION_ID=
ZOHO_DEFAULT_ITEM_ID=
ZOHO_DEFAULT_TAX_ID=

# Optional
ZOHO_DEFAULT_PAYMENT_TERMS=0
# Set true when Shopify product prices already include GST.
ZOHO_INCLUSIVE_TAX=true
